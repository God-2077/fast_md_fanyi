{
  "name": "fanyi",
  "version": "2.0.0",
  "description": "Markdown 文件批量翻译工具",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "translation",
    "markdown",
    "i18n"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^10.2.1",
    "eslint-plugin-n": "^17.24.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "front-matter": "^4.0.2",
    "glob": "^11.0.0",
    "js-yaml": "^4.1.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
