# ========== API 配置 ==========
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.siliconflow.cn/v1
OPENAI_MODEL=Qwen/Qwen3-8B

# ========== 请求参数 ==========
OPENAI_TEMPERATURE=0.5
OPENAI_MAX_TOKENS=1000
OPENAI_STREAM=true
OPENAI_TIMEOUT=60000

# ========== 并发与重试 ==========
OPENAI_THREAD_COUNT=2
OPENAI_RETRY_COUNT=3
OPENAI_RATE_LIMIT_WAIT=10000
OPENAI_MAX_CONSECUTIVE_ERRORS=5
OPENAI_MAX_RETRIES_BEHAVIOR=skip
OPENAI_LOG_STREAM_DELTA=false

# ========== 智能策略 ==========
OPENAI_SMART_TOKENS=true
OPENAI_SMART_TIMEOUT=true
OPENAI_CHECK_MANGLED=true

# ========== Mock 模式（不调用真实 API） ==========
OPENAI_MOCK=false
OPENAI_MOCK_DELAY=0

# ========== 翻译配置 ==========
TRANSLATION_MAX_CHAR_LENGTH=25000
TRANSLATION_PRESERVED_TERMS_PLACEHOLDER=true

# ========== 文件配置 ==========
INPUT_FOLDER=input
OUTPUT_FOLDER=output
FILE_PRESERVE_FOLDERS=true
FILE_COPY_OTHER_FILES=true
FILE_SKIP_UNCHANGED=true

# ========== 日志配置 ==========
LOG_LEVEL=debug
LOG_TO_FILE=true
LOG_FILE_PATH=./logs/app-{local}.log

# ========== 报告配置 ==========
REPORT_ENABLED=true
REPORT_OUTPUT=./output/translation-report-{local}.json
